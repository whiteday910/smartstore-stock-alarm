# ── Supabase ────────────────────────────────────────────────
# Supabase 프로젝트 > Settings > API 에서 확인
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Gmail ───────────────────────────────────────────────────
# 발신에 사용할 Gmail 주소
GMAIL_USER=your-email@gmail.com
# Google 계정 > 보안 > 앱 비밀번호 (2단계 인증 활성화 필요)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── 서비스 URL ──────────────────────────────────────────────
# 로컬 개발: Next.js 주소 (구독취소 링크·이메일에 사용)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# 배포 시 Vercel URL 로 변경
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# GitHub Actions 가 Vercel 프록시를 쓸 때만 필요 (로컬은 비워도 됨)
# BASE_URL=https://your-app.vercel.app

# ── Vercel 프록시 인증 시크릿 ────────────────────────────────
# GitHub Actions ↔ Vercel /api/check-url 통신 인증용
# 임의의 긴 문자열로 설정 (예: openssl rand -hex 32)
CHECK_API_SECRET=your-random-secret-here
